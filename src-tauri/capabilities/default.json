  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Aura Companion default window capabilities",
  "windows": ["main", "pet"],
  "permissions": [
    "core:default",
    "core:window:allow-set-position",
    "core:window:allow-set-shadow",
    "core:window:allow-start-dragging"
